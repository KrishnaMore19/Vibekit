# VibeKit Studio — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# PostgreSQL connection string
# Supabase example: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Neon example:     postgresql://[user]:[password]@[host]/[db]?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/vibekit

# JWT secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-to-a-very-long-random-secret

# Your deployed Netlify URL (for CORS in production)
# Leave blank for local dev
CLIENT_URL=https://your-app.netlify.app
